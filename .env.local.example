NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# For blueprint AI analysis — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
