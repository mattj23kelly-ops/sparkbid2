# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Supabase — Project Settings → API in the dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Service-role key (keep secret — server-side only).
# Used for auth.users email lookup and the notification_log writes.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Anthropic — blueprint take-off + estimate generation
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY

# Resend — transactional emails (new bid, bid awarded, verification decisions).
# Create an account at https://resend.com, verify a sending domain, then copy
# the API key and the "From" address you verified.
RESEND_API_KEY=re_YOUR_KEY
RESEND_FROM_EMAIL=SparkBid <no-reply@your-domain.com>

# Absolute URL used to build links inside outbound emails.
# Locally this is http://localhost:3000; in production use your Vercel URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
